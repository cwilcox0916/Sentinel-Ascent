{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Sentinel Ascent",
  "version": "0.1.0",
  "identifier": "com.sentinelascent.game",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Sentinel Ascent",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "deb", "appimage", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Game",
    "shortDescription": "A radial survival-defense incremental for PC and tablet.",
    "longDescription": "Sentinel Ascent is a single-player radial survival-defense incremental game with no microtransactions. Run a stationary defense node holding off escalating waves; earn permanent progression across Forge, Research Bay, Protocols, Augments, Arsenals, Constructs, Heirlooms, Order, Warden, and the Archive tech tree.",
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "frameworks": []
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": ["https://sentinelascent.example/updates/{{target}}-{{arch}}/{{current_version}}"],
      "dialog": false
    }
  }
}
